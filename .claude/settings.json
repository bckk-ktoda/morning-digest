{
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(pip install jpholiday*)",
      "Read(state/*)",
      "Write(state/*)",
      "Edit(state/*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx claude-task-viewer --open &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/on_stop.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/on_stop.sh"
          }
        ]
      }
    ]
  }
}
