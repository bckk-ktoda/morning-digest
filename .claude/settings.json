{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(pip install jpholiday*)",
      "Read(state/*)",
      "Write(state/*)",
      "Edit(state/*)",
      "Agent(*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pkill -f claude-task-viewer 2>/dev/null; sleep 0.3; npx claude-task-viewer --open >/tmp/claude-task-viewer.log 2>&1 &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/on_stop.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/on_stop.sh"
          }
        ]
      }
    ]
  }
}
